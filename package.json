    "@mastra/pg": "^1.9.1",
    "@renderinc/sdk": "^0.5.0",
    "hono": "^4.0.0",
    "pg": "^8.13.0",
    "pino": "^9.0.0",
    "ws": "^8.18.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/ws": "^8.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
