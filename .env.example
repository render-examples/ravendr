# AssemblyAI Voice Agent API
ASSEMBLYAI_API_KEY=your_assemblyai_api_key

# You.com Research API
YOU_API_KEY=your_you_api_key

# Render (for triggering workflows from the web service)
RENDER_API_KEY=your_render_api_key
WORKFLOW_SLUG=ravendr-workflows
# Optional: override dashboard link in the UI (must be http(s); default https://dashboard.render.com)
# RENDER_DASHBOARD_TASKS_URL=https://dashboard.render.com

# PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/ravendr

# LLM (Mastra agents use Anthropic by default)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Optional
ANTHROPIC_MODEL=claude-sonnet-4-20250514
PORT=3000

# Set false to disable WebSocket voice at /ws/voice (HTTP + workflows unchanged)
ENABLE_VOICE_WEBSOCKET=true
# Final user transcripts can start workflows even if the model does not emit tool.call. Set 0 to disable.
# VOICE_TRANSCRIPT_DISPATCH=1
